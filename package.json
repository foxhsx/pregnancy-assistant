{
  "name": "yunqi-static-site-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "install:browsers": "node ./scripts/install-playwright.mjs",
    "lint": "eslint . --max-warnings=0",
    "validate:content": "node ./scripts/validate-content-registry.mjs",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test",
    "test:e2e:no-server": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --config=playwright.no-server.config.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "http-server": "^14.1.1",
    "vite": "^6.2.2"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "peerjs": "^1.5.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
